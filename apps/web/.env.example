# Copy to apps/web/.env.local. Get the keys from your Clerk dashboard
# (https://dashboard.clerk.com → Configure → API keys).

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Where Clerk redirects after sign-out (UserButton, etc.). Default: "/".
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Where the FastAPI service is reachable from the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
