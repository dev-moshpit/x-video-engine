# ─── Local dev defaults ─────────────────────────────────────────────────
# Copy to .env (and apps/web/.env.local for the Next.js app) and fill in
# the secrets when each PR needs them. PR 1 ships with no real secrets.

# === FastAPI ===
API_PORT=8000
API_BASE_URL=http://localhost:8000

# === Next.js ===
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# === Postgres (docker-compose.dev.yaml) ===                  PR 3 wires this in
DATABASE_URL=postgresql://saas:saas@localhost:5432/saas

# === Redis (docker-compose.dev.yaml) ===                     PR 6 wires this in
REDIS_URL=redis://localhost:6379/0

# === Object storage — local MinIO emulating R2 ===           PR 7 wires this in
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=renders-dev
R2_PUBLIC_BASE_URL=http://localhost:9000/renders-dev

# === Auth — Clerk ===                                         PR 2 wires these in
# Frontend keys (also belong in apps/web/.env.local — see apps/web/.env.example)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend JWT verification — issuer URL of your Clerk Frontend API,
# e.g. https://your-app.clerk.accounts.dev (dev) or https://clerk.your-domain.com (prod).
# The api fetches `${CLERK_JWT_ISSUER}/.well-known/jwks.json` to verify session JWTs.
CLERK_JWT_ISSUER=
# Optional: set if you mint Clerk JWTs with a custom audience claim.
CLERK_AUDIENCE=

# Clerk webhook signing secret — get this from Clerk Dashboard → Webhooks
# after adding ${API_BASE_URL}/api/webhooks/clerk as an endpoint. PR 3 uses
# this to verify Svix signatures on user.created / user.updated / user.deleted
# events. In dev you can leave it blank; the lazy upsert on /api/me keeps
# the DB in sync without webhooks.
CLERK_WEBHOOK_SECRET=

# === Media library — Phase 2.5 ===
# Both providers are optional; the search endpoint silently skips a
# provider when its key is missing and surfaces the skip in
# `warnings[]` so the frontend can prompt the operator to set them up.
PEXELS_API_KEY=
PIXABAY_API_KEY=

# === Stripe billing — Phase 3 ===
# Server secret + webhook signing secret. Without these set the api
# returns 503 from /api/billing/checkout, /api/billing/portal, and
# /api/webhooks/stripe — render gating + tier resolution still work
# (free tier with the starter grant).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs created via the Stripe dashboard or `stripe prices
# create`. These map our internal tier names to recurring-subscription
# prices. Tiers without a configured price are non-purchaseable in the
# /api/billing/tiers catalog.
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
