# ─── Local dev defaults ─────────────────────────────────────────────────
# Copy to .env (and apps/web/.env.local for the Next.js app) and fill in
# the secrets when each PR needs them. PR 1 ships with no real secrets.

# === FastAPI ===
API_PORT=8000
API_BASE_URL=http://localhost:8000

# === Next.js ===
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# === Postgres (docker-compose.dev.yaml) ===                  PR 3 wires this in
DATABASE_URL=postgresql://saas:saas@localhost:5432/saas

# === Redis (docker-compose.dev.yaml) ===                     PR 6 wires this in
REDIS_URL=redis://localhost:6379/0

# === Object storage — local MinIO emulating R2 ===           PR 7 wires this in
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=renders-dev
R2_PUBLIC_BASE_URL=http://localhost:9000/renders-dev

# === Auth — Clerk ===                                         PR 2 wires these in
# Frontend keys (also belong in apps/web/.env.local — see apps/web/.env.example)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend JWT verification — issuer URL of your Clerk Frontend API,
# e.g. https://your-app.clerk.accounts.dev (dev) or https://clerk.your-domain.com (prod).
# The api fetches `${CLERK_JWT_ISSUER}/.well-known/jwks.json` to verify session JWTs.
CLERK_JWT_ISSUER=
# Optional: set if you mint Clerk JWTs with a custom audience claim.
CLERK_AUDIENCE=
