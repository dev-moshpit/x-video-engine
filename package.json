{
  "name": "x-video-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @xve/web dev",
    "build:web": "pnpm --filter @xve/web build",
    "typecheck:web": "pnpm --filter @xve/web typecheck",
    "dev:api": "py -3.11 -m uvicorn app.main:app --reload --port 8000 --app-dir apps/api",
    "dev:worker": "py -3.11 apps/worker/main.py",
    "dev:infra": "docker compose -f docker-compose.dev.yaml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yaml down",
    "dev:db:upgrade": "py -3.11 -m alembic -c apps/api/alembic.ini upgrade head",
    "dev:db:downgrade": "py -3.11 -m alembic -c apps/api/alembic.ini downgrade -1",
    "dev:db:revision": "py -3.11 -m alembic -c apps/api/alembic.ini revision --autogenerate -m",
    "test:api": "py -3.11 -m pytest tests/api",
    "test:worker": "py -3.11 -m pytest tests/worker",
    "test": "py -3.11 -m pytest tests/api tests/worker"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
